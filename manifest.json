{
  "manifest_version": 3,
  "name": "MemeScanner",
  "version": "1.1.0",
  "description": "Real-time axiom.trade token monitor — detects new coins, filters by quality, and monitors matches.",
  "permissions": [
    "tabs",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://axiom.trade/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://axiom.trade/*"],
      "js": ["utils.js", "content-router.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
