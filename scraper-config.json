{
  "updateIntervalMs": 250,
  "debounceMs": 140,
  "maxTokensPerBatch": 120,
  "platformPresets": {
    "axiom": {
      "hosts": ["axiom.trade"],
      "listContainer": "section[aria-label='Table content']",
      "row": "div[data-index]",
      "fields": {
        "ticker": "div.truncate",
        "age": "span[class*='text-primaryGreen']",
        "marketCap": "span[class*='text-textPrimary']",
        "liquidity": "span[class*='text-textPrimary']",
        "volume": "span[class*='text-textPrimary']"
      },
      "auditRules": ["honeypot", "mintAuthorityEnabled", "freezeAuthorityEnabled"]
    },
    "gmgn": {
      "hosts": ["gmgn.ai"],
      "listContainer": ".g-table-body",
      "row": "div[data-index]",
      "fields": {
        "ticker": "span[data-sentry-component='TooltipCopy']",
        "name": "div[data-sentry-component='TokenBaseInfo'] div.truncate",
        "age": "div.text-green-50.font-medium",
        "marketCap": "div[data-sentry-component='Volume'] > div:nth-child(2) > span:nth-child(2)",
        "volume": "div[data-sentry-component='Volume'] > div:nth-child(1) > span:nth-child(2)",
        "liquidity": "div[class*='pl-[2px]'] > div:nth-child(1) > span.text-text-100",
        "txCount": "div[class*='pl-[2px]'] > div:nth-child(3) > span.text-text-100",
        "twitter": "a[aria-label='twitter']",
        "website": "a[aria-label='website']",
        "holders": "div[data-sentry-component='HolderView']"
      },
      "auditRules": ["honeypot", "mintAuthorityEnabled"]
    }
  }
}
